<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><%= t('nav.home') %></a>
          </li>
        </ul>
        <ul class="navbar-nav">
          <% if (user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle me-1"></i><%= user.display_name || user.username %>
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin"><i class="bi bi-speedometer2 me-2"></i><%= t('nav.admin') %></a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
              </ul>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/auth/login?lang=<%= lang %>"><i class="bi bi-box-arrow-in-right me-1"></i><%= t('nav.login') %></a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/?lang=<%= lang %>"><%= t('nav.home') %></a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= car.brand %> <%= car.model %></li>
      </ol>
    </nav>

    <div class="row g-4">
      <!-- Image Gallery -->
      <div class="col-lg-7">
        <div class="card shadow-sm">
          <div id="carMediaCarousel" class="carousel slide" data-bs-ride="carousel">
            <%
            const images = media ? media.filter(m => m.file_type === 'image') : [];
            const videos = media ? media.filter(m => m.file_type === 'video') : [];
            const allMedia = [...images, ...videos];
            %>
            <div class="carousel-inner rounded-top">
              <% if (allMedia.length > 0) { %>
                <% allMedia.forEach(function(item, idx) { %>
                <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                  <% if (item.file_type === 'image') { %>
                    <img src="<%= item.file_path %>" class="d-block w-100" style="max-height:500px; object-fit:cover;" alt="<%= t('car.description') %>">
                  <% } else { %>
                    <video class="d-block w-100" style="max-height:500px;" controls>
                      <source src="<%= item.file_path %>">
                    </video>
                  <% } %>
                </div>
                <% }); %>
              <% } else { %>
                <div class="carousel-item active">
                  <div class="no-image-placeholder d-flex align-items-center justify-content-center bg-light" style="height:400px;">
                    <i class="bi bi-car-front text-muted" style="font-size: 6rem;"></i>
                  </div>
                </div>
              <% } %>
            </div>
            <% if (allMedia.length > 1) { %>
            <button class="carousel-control-prev" type="button" data-bs-target="#carMediaCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carMediaCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Car Info -->
      <div class="col-lg-5">
        <div class="card shadow-sm">
          <div class="card-body">
            <h2 class="card-title mb-3"><%= car.brand %> <%= car.model %></h2>
            
            <h3 class="text-danger fw-bold mb-4">
              <% if (car.price) { %>$ <%= Number(car.price).toLocaleString() %><% } else { %><%= t('car.priceNegotiable') %><% } %>
            </h3>

            <div class="row g-3 mb-3">
              <div class="col-6">
                <div class="border rounded p-2 text-center">
                  <small class="text-muted d-block"><%= t('car.registrationYear') %></small>
                  <strong><%= car.year ? car.year + t('car.year') : t('car.notFilled') %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="border rounded p-2 text-center">
                  <small class="text-muted d-block"><%= t('car.odometer') %></small>
                  <strong><%= car.mileage ? Number(car.mileage).toLocaleString() + ' ' + t('car.km') : t('car.notFilled') %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="border rounded p-2 text-center">
                  <small class="text-muted d-block"><%= t('car.transmission') %></small>
                  <strong><%= car.transmission || t('car.notFilled') %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="border rounded p-2 text-center">
                  <small class="text-muted d-block"><%= t('car.fuelType') %></small>
                  <strong><%= car.fuel_type || t('car.notFilled') %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="border rounded p-2 text-center">
                  <small class="text-muted d-block"><%= t('car.color') %></small>
                  <strong><%= car.color || t('car.notFilled') %></strong>
                </div>
              </div>
              <div class="col-6">
                <div class="border rounded p-2 text-center">
                  <small class="text-muted d-block"><%= t('car.displacement') %></small>
                  <strong><%= car.displacement || t('car.notFilled') %></strong>
                </div>
              </div>
            </div>

            <% if (car.status === 'active') { %>
            <span class="badge bg-success fs-6 px-3 py-2 mb-3"><%= t('car.forSale') %></span>
            <% } else { %>
            <span class="badge bg-secondary fs-6 px-3 py-2 mb-3"><%= t('car.sold') %></span>
            <% } %>

            <% if (car.description) { %>
            <h5 class="mt-3"><%= t('car.description') %></h5>
            <p class="text-muted"><%= car.description %></p>
            <% } %>

            <% const hasCarContacts = (car.contact_wechat || car.contact_whatsapp || car.contact_email); %>
            <% if (hasCarContacts) { %>
            <div class="alert alert-primary mt-3">
              <h5 class="alert-heading mb-3"><i class="bi bi-telephone me-2"></i><%= t('car.contact') || '联系方式' %></h5>
              <div class="row g-3">
                <% if (car.contact_wechat) { %>
                <div class="col-auto">
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-success fs-6 px-3 py-2"><i class="bi bi-wechat me-1"></i><%= t('car.wechat') || '微信' %>: <%= car.contact_wechat %></span>
                  </div>
                </div>
                <% } %>
                <% if (car.contact_whatsapp) { %>
                <div class="col-auto">
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-secondary fs-6 px-3 py-2"><i class="bi bi-whatsapp me-1"></i>WhatsApp: <%= car.contact_whatsapp %></span>
                  </div>
                </div>
                <% } %>
                <% if (car.contact_email) { %>
                <div class="col-auto">
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-dark fs-6 px-3 py-2"><i class="bi bi-envelope me-1"></i><%= t('car.email') || '邮箱' %>: <%= car.contact_email %></span>
                  </div>
                </div>
                <% } %>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-4">
      <a href="/?lang=<%= lang %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i><%= t('car.backToList') %></a>
    </div>
  </div>

  <footer class="bg-dark text-light py-4 mt-5">
    <div class="container text-center">
      <p class="mb-1"><i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %> - <%= t('siteSlogan') %></p>
      <p class="text-muted small mb-0">&copy; 2026 <%= t('siteName') %>. <%= t('footer.copyright') %>.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
