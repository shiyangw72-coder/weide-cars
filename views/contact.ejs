<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .contact-hero {
      background: linear-gradient(135deg, rgba(13, 17, 23, 0.88) 0%, rgba(22, 33, 62, 0.82) 100%),
                  url('https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=1920&q=80') center/cover no-repeat;
      color: white;
      padding: 4rem 0 3rem;
      text-align: center;
    }
    .contact-hero h1 {
      text-shadow: 2px 2px 8px rgba(0,0,0,0.4);
      font-weight: 700;
    }
    .contact-icon-box {
      width: 70px; height: 70px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 1rem;
    }
    .contact-card {
      border: none;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      transition: transform 0.2s, box-shadow 0.2s;
      height: 100%;
    }
    .contact-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    }
    .contact-card .card-body { padding: 2rem; }
    .wechat-qr-box {
      background: #f0f9f0;
      border: 2px dashed #52c41a;
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }
    .wechat-qr-box i { font-size: 3rem; color: #52c41a; }
    .info-row { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.5rem; }
    .info-row i { margin-top: 3px; flex-shrink: 0; }
    @media (max-width: 768px) {
      .contact-hero { padding: 2.5rem 0 2rem; }
      .contact-hero h1 { font-size: 1.8rem; }
    }
  </style>
</head>
<body>

  <!-- Navbar (same as index) -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><%= t('nav.home') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><%= t('nav.cars') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/export?lang=<%= lang %>"><%= t('nav.export') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/about?lang=<%= lang %>"><%= t('nav.about') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/contact?lang=<%= lang %>"><%= t('nav.contact') %></a>
          </li>
        </ul>
        <ul class="navbar-nav me-3">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <%= currentLang.flag %> <%= currentLang.name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/?lang=zh">🇨🇳 中文</a></li>
              <li><a class="dropdown-item" href="/?lang=en">🇬🇧 English</a></li>
              <li><a class="dropdown-item" href="/?lang=fr">🇫🇷 Français</a></li>
            </ul>
          </li>
        </ul>
        <ul class="navbar-nav">
          <% if (user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/auth/login?lang=<%= lang %>"><i class="bi bi-box-arrow-in-right me-1"></i><%= t('nav.login') %></a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <div class="contact-hero">
    <div class="container">
      <h1 class="display-5 fw-bold mb-3"><%= t('contact.pageTitle') %></h1>
      <p class="lead opacity-75 mb-0"><%= t('contact.subtitle') %></p>
    </div>
  </div>

  <!-- Contact Cards -->
  <div class="container py-5">
    <div class="row g-4">

      <% if (siteContacts.contact_wechat) { %>
      <!-- WeChat -->
      <div class="col-md-6 col-lg-4">
        <div class="contact-card card text-center">
          <div class="card-body">
            <div class="contact-icon-box bg-success bg-opacity-10 text-success">
              <i class="bi bi-wechat"></i>
            </div>
            <h5 class="mb-3"><%= t('contact.wechat') %></h5>
            <p class="text-muted mb-3"><%= t('contact.wechatTip') %></p>
            <div class="wechat-qr-box">
              <i class="bi bi-qr-code d-block mb-2"></i>
              <strong class="d-block mb-1"><%= siteContacts.contact_wechat %></strong>
              <small class="text-muted"><%= t('contact.scanToAdd') %></small>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <% if (siteContacts.contact_whatsapp) { %>
      <!-- WhatsApp -->
      <div class="col-md-6 col-lg-4">
        <div class="contact-card card text-center">
          <div class="card-body">
            <div class="contact-icon-box" style="background: rgba(37,211,102,0.1); color: #25D366;">
              <i class="bi bi-whatsapp"></i>
            </div>
            <h5 class="mb-3"><%= t('contact.whatsapp') %></h5>
            <p class="text-muted mb-3"><%= t('contact.whatsappTip') %></p>
            <a href="https://wa.me/<%= siteContacts.contact_whatsapp.replace(/[^0-9]/g, '') %>" 
               target="_blank" class="btn btn-success w-100">
              <i class="bi bi-whatsapp me-2"></i><%= t('contact.openWhatsapp') %>
            </a>
          </div>
        </div>
      </div>
      <% } %>

      <% if (siteContacts.contact_email) { %>
      <!-- Email -->
      <div class="col-md-6 col-lg-4">
        <div class="contact-card card text-center">
          <div class="card-body">
            <div class="contact-icon-box" style="background: rgba(0,123,255,0.1); color: #0d6efd;">
              <i class="bi bi-envelope-at"></i>
            </div>
            <h5 class="mb-3"><%= t('contact.email') %></h5>
            <p class="text-muted mb-3"><%= t('contact.emailTip') %></p>
            <a href="mailto:<%= siteContacts.contact_email %>" class="btn btn-primary w-100">
              <i class="bi bi-envelope me-2"></i><%= siteContacts.contact_email %>
            </a>
          </div>
        </div>
      </div>
      <% } %>

      <% if (siteContacts.contact_phone) { %>
      <!-- Phone -->
      <div class="col-md-6 col-lg-4">
        <div class="contact-card card text-center">
          <div class="card-body">
            <div class="contact-icon-box" style="background: rgba(255,193,7,0.1); color: #ffc107;">
              <i class="bi bi-telephone"></i>
            </div>
            <h5 class="mb-3"><%= t('contact.phone') %></h5>
            <p class="text-muted mb-3"><%= t('contact.phoneTip') %></p>
            <a href="tel:<%= siteContacts.contact_phone %>" class="btn btn-warning w-100">
              <i class="bi bi-telephone me-2"></i><%= siteContacts.contact_phone %>
            </a>
          </div>
        </div>
      </div>
      <% } %>

      <% if (siteContacts.contact_address) { %>
      <!-- Address -->
      <div class="col-md-6 col-lg-4">
        <div class="contact-card card text-center">
          <div class="card-body">
            <div class="contact-icon-box" style="background: rgba(111,66,193,0.1); color: #6f42c1;">
              <i class="bi bi-geo-alt"></i>
            </div>
            <h5 class="mb-3"><%= t('contact.address') %></h5>
            <p class="text-muted mb-3"><%= t('contact.addressTip') %></p>
            <p class="fw-medium mb-0"><%= siteContacts.contact_address %></p>
          </div>
        </div>
      </div>
      <% } %>

      <% if (!siteContacts.contact_wechat && !siteContacts.contact_whatsapp && !siteContacts.contact_email && !siteContacts.contact_phone && !siteContacts.contact_address) { %>
      <!-- Empty state -->
      <div class="col-12 text-center py-5">
        <i class="bi bi-telephone-x text-muted" style="font-size: 4rem;"></i>
        <h4 class="mt-3 text-muted"><%= t('contact.noContact') %></h4>
        <p class="text-muted"><%= t('contact.noContactTip') %></p>
      </div>
      <% } %>

    </div>

    <!-- Business Hours -->
    <div class="mt-5 text-center">
      <div class="alert alert-info d-inline-flex align-items-center gap-2">
        <i class="bi bi-clock-history"></i>
        <span><%= t('contact.businessHours') || '营业时间：周一至周六  9:00 - 18:00（北京时间）' %></span>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-light py-4 mt-auto">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-5">
          <p class="mb-1"><i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %> - <%= t('siteSlogan') %></p>
          <p class="text-muted small mb-0">&copy; 2026 <%= t('siteName') %>. <%= t('footer.copyright') %>.</p>
        </div>
        <div class="col-md-7 text-md-end">
          <a href="/" class="text-muted small"><%= t('nav.home') %></a>
          <span class="text-muted mx-2">|</span>
          <a href="/contact?lang=<%= lang %>" class="text-muted small"><%= t('nav.contact') %></a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
