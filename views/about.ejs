<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('about.pageTitle') %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .about-hero {
      background: linear-gradient(135deg, rgba(13,17,23,0.90) 0%, rgba(22,33,62,0.85) 100%),
                  url('https://images.unsplash.com/photo-1493238792000-8113da705763?w=1920&q=80') center/cover no-repeat;
      color: white;
      padding: 5rem 0 4rem;
      text-align: center;
    }
    .about-hero h1 {
      text-shadow: 2px 2px 8px rgba(0,0,0,0.4);
      font-weight: 700;
    }
    .about-hero .lead {
      opacity: 0.85;
      max-width: 600px;
      margin: 0.75rem auto 0;
    }
    .section-title {
      position: relative;
      padding-bottom: 0.75rem;
      margin-bottom: 2rem;
    }
    .section-title::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 50px;
      height: 3px;
      background: #0d6efd;
      border-radius: 2px;
    }
    .section-title.centered::after {
      left: 50%;
      transform: translateX(-50%);
    }
    .story-card {
      background: white;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.07);
      overflow: hidden;
    }
    .story-card .story-img {
      height: 100%;
      min-height: 280px;
      background: url('https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?w=800&q=80') center/cover;
    }
    .story-card .story-body {
      padding: 2.5rem;
    }
    .value-card {
      background: white;
      border-radius: 16px;
      padding: 2rem 1.5rem;
      text-align: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
      border: 1px solid rgba(0,0,0,0.05);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      height: 100%;
    }
    .value-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 36px rgba(0,0,0,0.12);
    }
    .value-icon {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      margin: 0 auto 1rem;
    }
    .service-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      border-left: 4px solid #0d6efd;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      height: 100%;
    }
    .contact-footer-card {
      background: linear-gradient(135deg, #0d6efd, #0a58ca);
      color: white;
      border-radius: 20px;
      padding: 3rem;
    }
    .contact-footer-card a { color: rgba(255,255,255,0.85); text-decoration: none; }
    .contact-footer-card a:hover { color: white; }
    .info-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }
    .info-item i { font-size: 1.2rem; margin-top: 2px; flex-shrink: 0; opacity: 0.9; }
    @media (max-width: 768px) {
      .about-hero { padding: 2.5rem 0 2.5rem; }
      .story-card .story-body { padding: 1.75rem; }
      .contact-footer-card { padding: 2rem 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><%= t('nav.home') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><%= t('nav.cars') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/export?lang=<%= lang %>"><%= t('nav.export') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/about?lang=<%= lang %>"><%= t('nav.about') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contact?lang=<%= lang %>"><%= t('nav.contact') %></a>
          </li>
        </ul>
        <ul class="navbar-nav me-3">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <%= currentLang.flag %> <%= currentLang.name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/?lang=zh">🇨🇳 中文</a></li>
              <li><a class="dropdown-item" href="/?lang=en">🇬🇧 English</a></li>
              <li><a class="dropdown-item" href="/?lang=fr">🇫🇷 Français</a></li>
            </ul>
          </li>
        </ul>
        <ul class="navbar-nav">
          <% if (user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/auth/login?lang=<%= lang %>"><i class="bi bi-box-arrow-in-right me-1"></i><%= t('nav.login') %></a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <div class="about-hero">
    <div class="container">
      <h1><i class="bi bi-car-front-fill me-3"></i><%= t('siteName') %></h1>
      <p class="lead"><%= t('about.subtitle') %></p>
    </div>
  </div>

  <!-- Company Story -->
  <div class="container py-5">
    <div class="section-title text-center">
      <h2 class="fw-bold"><%= t('about.storyTitle') %></h2>
    </div>
    <div class="row align-items-center">
      <div class="col-lg-6 mb-4 mb-lg-0">
        <div class="story-card h-100">
          <div class="story-img d-none d-lg-block"></div>
          <div class="story-body">
            <div class="d-flex align-items-center mb-3">
              <div class="me-3">
                <div style="width:56px;height:56px;background:#0d6efd;border-radius:12px;display:flex;align-items:center;justify-content:center;">
                  <i class="bi bi-geo-alt-fill text-white" style="font-size:1.4rem;"></i>
                </div>
              </div>
              <div>
                <div class="fw-bold"><%= t('siteName') %></div>
                <small class="text-muted"><%= t('about.addressLabel') %>：<%= lang === 'zh' ? '安徽省阜阳市' : 'Fuyang, Anhui' %></div>
              </div>
            </div>
            <p class="text-muted mb-0" style="line-height:1.8;">
              <% if (lang === 'zh') { %>
              和谐新村一期45号103-105<br>
              开发区核心地段，展厅环境规范
              <% } else { %>
              Suite 103-105, Phase 1, Hexie Xin Village, Development Zone<br>
              Prime location in Fuyang Development Zone
              <% } %>
            </p>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <p style="line-height:1.9; font-size:1.05rem; color:#444;">
          <%= t('about.storyText1') %>
        </p>
        <p style="line-height:1.9; font-size:1.05rem; color:#444;">
          <%= t('about.storyText2') %>
        </p>
        <div class="p-3 rounded-3 mt-3" style="background: linear-gradient(135deg, #e7f1ff, #f0f7ff); border-left: 4px solid #0d6efd;">
          <p class="mb-0 fst-italic" style="line-height:1.8; color:#333; font-size:0.98rem;">
            "<%= t('about.storyText3') %>"
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Divider -->
  <div style="background: linear-gradient(90deg, transparent, #0d6efd33, transparent); height: 1px;"></div>

  <!-- Our Values -->
  <div class="container py-5">
    <div class="section-title text-center">
      <h2 class="fw-bold"><%= t('about.valuesTitle') %></h2>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: rgba(13,110,253,0.1); color: #0d6efd;">
            <i class="bi bi-shield-check"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value1Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value1Desc') %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: rgba(25,135,84,0.1); color: #198754;">
            <i class="bi bi-award"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value2Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value2Desc') %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: rgba(255,193,7,0.15); color: #ffc107;">
            <i class="bi bi-car-front"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value3Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value3Desc') %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: rgba(111,66,193,0.1); color: #6f42c1;">
            <i class="bi bi-heart-pulse"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value4Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value4Desc') %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Divider -->
  <div style="background: linear-gradient(90deg, transparent, #0d6efd33, transparent); height: 1px;"></div>

  <!-- Services -->
  <div class="container py-5">
    <div class="section-title text-center">
      <h2 class="fw-bold"><%= t('about.businessTitle') %></h2>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="service-card">
          <div class="d-flex align-items-center mb-3">
            <div style="width:44px;height:44px;background:#e7f1ff;border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-stars text-primary" style="font-size:1.2rem;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.businessNew') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.businessNewDesc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="service-card">
          <div class="d-flex align-items-center mb-3">
            <div style="width:44px;height:44px;background:#e8f5e9;border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-car-rear text-success" style="font-size:1.2rem;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.businessUsed') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.businessUsedDesc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="service-card">
          <div class="d-flex align-items-center mb-3">
            <div style="width:44px;height:44px;background:#fff3e0;border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-people text-warning" style="font-size:1.2rem;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.businessWholesale') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.businessWholesaleDesc') %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact CTA -->
  <div class="container pb-5">
    <div class="contact-footer-card text-center">
      <h3 class="fw-bold mb-2"><i class="bi bi-telephone-fill me-2"></i><%= t('about.contactTitle') %></h3>
      <p class="mb-4 opacity-75"><%= t('about.welcome') %></p>
      <div class="row justify-content-center g-4 text-start">
        <% if (siteContacts.contact_phone) { %>
        <div class="col-md-5">
          <div class="info-item">
            <i class="bi bi-telephone"></i>
            <div>
              <div class="small opacity-75"><%= t('about.hoursLabel') %></div>
              <div><a href="tel:<%= siteContacts.contact_phone %>"><%= siteContacts.contact_phone %></a></div>
            </div>
          </div>
        </div>
        <% } %>
        <% if (siteContacts.contact_address) { %>
        <div class="col-md-5">
          <div class="info-item">
            <i class="bi bi-geo-alt-fill"></i>
            <div>
              <div class="small opacity-75"><%= t('about.addressLabel') %></div>
              <div><%= siteContacts.contact_address %></div>
            </div>
          </div>
        </div>
        <% } %>
        <% if (!siteContacts.contact_phone && !siteContacts.contact_address) { %>
        <div class="col-12">
          <div class="info-item justify-content-center">
            <i class="bi bi-clock"></i>
            <div>
              <div class="small opacity-75"><%= t('about.hoursLabel') %></div>
              <div><%= t('about.hoursValue') %></div>
            </div>
          </div>
        </div>
        <% } %>
      </div>
      <div class="mt-4">
        <a href="/contact?lang=<%= lang %>" class="btn btn-light px-4">
          <i class="bi bi-chat-dots me-2"></i><%= t('nav.contact') %>
        </a>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-light py-4 mt-auto">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-5">
          <p class="mb-1"><i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %> - <%= t('siteSlogan') %></p>
          <p class="text-muted small mb-0">&copy; 2026 <%= t('siteName') %>. <%= t('footer.copyright') %>.</p>
        </div>
        <div class="col-md-7 text-md-end">
          <a href="/" class="text-muted small"><%= t('nav.home') %></a>
          <span class="text-muted mx-2">|</span>
          <a href="/contact?lang=<%= lang %>" class="text-muted small"><%= t('nav.contact') %></a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
