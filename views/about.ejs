<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('about.pageTitle') %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .about-hero {
      background: linear-gradient(135deg, rgba(13,17,23,0.92) 0%, rgba(22,33,62,0.88) 100%),
                  url('https://images.unsplash.com/photo-1493238792000-8113da705763?w=1920&q=80') center/cover no-repeat;
      color: white;
      padding: 6rem 0 5rem;
      text-align: center;
    }
    .about-hero h1 {
      text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
      font-weight: 800;
      font-size: 2.8rem;
    }
    .about-hero .lead {
      opacity: 0.9;
      max-width: 700px;
      margin: 1rem auto 0;
      font-size: 1.25rem;
    }
    .section-title {
      position: relative;
      padding-bottom: 1rem;
      margin-bottom: 2.5rem;
    }
    .section-title::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 60px;
      height: 4px;
      background: linear-gradient(90deg, #0d6efd, #0a58ca);
      border-radius: 2px;
    }
    .section-title.centered::after {
      left: 50%;
      transform: translateX(-50%);
    }
    .section-title.centered { text-align: center; }
    
    /* 公司故事卡片 */
    .story-section {
      background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    }
    .story-card {
      background: white;
      border-radius: 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.04);
    }
    .story-card .story-img {
      height: 100%;
      min-height: 320px;
      background: linear-gradient(135deg, rgba(13,110,253,0.1), rgba(10,88,202,0.05)),
                  url('https://images.unsplash.com/photo-1568605117036-5fe5e7bab0b7?w=800&q=80') center/cover;
      position: relative;
    }
    .story-card .story-img::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.4), transparent 60%);
    }
    .story-card .story-body {
      padding: 2.5rem;
    }
    .story-body h4 {
      color: #1a1a2e;
      font-weight: 700;
      margin-bottom: 1rem;
    }
    .story-body p {
      color: #4a5568;
      line-height: 1.9;
      margin-bottom: 1rem;
    }
    
    /* 数据展示 */
    .stats-row {
      background: linear-gradient(135deg, #0d6efd, #0a58ca);
      border-radius: 16px;
      padding: 2rem;
      margin: 2rem 0;
    }
    .stat-item {
      text-align: center;
      color: white;
    }
    .stat-number {
      font-size: 2.5rem;
      font-weight: 800;
      display: block;
    }
    .stat-label {
      opacity: 0.9;
      font-size: 0.95rem;
    }
    
    /* 优势卡片 */
    .value-card {
      background: white;
      border-radius: 16px;
      padding: 2rem 1.5rem;
      text-align: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
      border: 1px solid rgba(0,0,0,0.04);
      transition: all 0.3s ease;
      height: 100%;
    }
    .value-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 16px 40px rgba(13,110,253,0.15);
    }
    .value-icon {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 1.25rem;
    }
    
    /* 服务卡片 */
    .service-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      border-left: 4px solid #0d6efd;
      box-shadow: 0 2px 12px rgba(0,0,0,0.05);
      height: 100%;
      transition: all 0.3s ease;
    }
    .service-card:hover {
      box-shadow: 0 8px 24px rgba(13,110,253,0.12);
      border-left-width: 6px;
    }
    
    /* 地图区域 */
    .map-section {
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }
    .map-container {
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
      border: 1px solid rgba(0,0,0,0.06);
    }
    .map-info {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }
    .map-info-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 0;
      border-bottom: 1px solid #f0f0f0;
    }
    .map-info-item:last-child { border-bottom: none; }
    .map-info-icon {
      width: 44px;
      height: 44px;
      background: linear-gradient(135deg, #e7f1ff, #f0f7ff);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0d6efd;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    
    /* CTA区域 */
    .contact-footer-card {
      background: linear-gradient(135deg, #0d6efd, #0a58ca);
      color: white;
      border-radius: 24px;
      padding: 3.5rem 2rem;
      position: relative;
      overflow: hidden;
    }
    .contact-footer-card::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 400px;
      height: 400px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
    }
    .contact-footer-card a { color: rgba(255,255,255,0.9); text-decoration: none; }
    .contact-footer-card a:hover { color: white; }
    .info-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }
    .info-item i { font-size: 1.2rem; margin-top: 2px; flex-shrink: 0; opacity: 0.9; }
    
    /* 时间线 */
    .timeline {
      position: relative;
      padding-left: 2rem;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 6px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(180deg, #0d6efd, #0a58ca);
    }
    .timeline-item {
      position: relative;
      padding-bottom: 1.5rem;
    }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: -1.65rem;
      top: 4px;
      width: 14px;
      height: 14px;
      background: #0d6efd;
      border-radius: 50%;
      border: 3px solid white;
      box-shadow: 0 0 0 2px #0d6efd;
    }
    
    @media (max-width: 768px) {
      .about-hero { padding: 3rem 0 2.5rem; }
      .about-hero h1 { font-size: 2rem; }
      .story-card .story-body { padding: 1.75rem; }
      .contact-footer-card { padding: 2rem 1.5rem; }
      .stat-number { font-size: 1.8rem; }
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><%= t('nav.home') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><%= t('nav.cars') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/export?lang=<%= lang %>"><%= t('nav.export') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/about?lang=<%= lang %>"><%= t('nav.about') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contact?lang=<%= lang %>"><%= t('nav.contact') %></a>
          </li>
        </ul>
        <ul class="navbar-nav me-3">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <%= currentLang.flag %> <%= currentLang.name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/about?lang=zh">🇨🇳 中文</a></li>
              <li><a class="dropdown-item" href="/about?lang=en">🇬🇧 English</a></li>
              <li><a class="dropdown-item" href="/about?lang=fr">🇫🇷 Français</a></li>
            </ul>
          </li>
        </ul>
        <ul class="navbar-nav">
          <% if (user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/auth/login?lang=<%= lang %>"><i class="bi bi-box-arrow-in-right me-1"></i><%= t('nav.login') %></a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <div class="about-hero">
    <div class="container">
      <h1><i class="bi bi-car-front-fill me-3"></i><%= t('siteName') %></h1>
      <p class="lead"><%= t('about.subtitle') %></p>
    </div>
  </div>

  <!-- Company Story -->
  <div class="story-section py-5">
    <div class="container">
      <div class="section-title centered">
        <h6 class="text-primary fw-bold text-uppercase ls-2 mb-2"><%= t('about.storySubtitle') %></h6>
        <h2 class="fw-bold"><%= t('about.storyTitle') %></h2>
      </div>
      
      <div class="row align-items-stretch g-4">
        <div class="col-lg-6">
          <div class="story-card h-100">
            <div class="story-img d-none d-lg-block"></div>
            <div class="story-body">
              <h4><i class="bi bi-building me-2 text-primary"></i><%= t('about.storyHeading') %></h4>
              <p><%= t('about.storyText1') %></p>
              <p><%= t('about.storyText2') %></p>
              <div class="p-3 rounded-3 mt-3" style="background: linear-gradient(135deg, #e7f1ff, #f0f7ff); border-left: 4px solid #0d6efd;">
                <p class="mb-0 fst-italic" style="line-height:1.8; color:#333;">
                  "<%= t('about.storyText3') %>"
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="story-card h-100">
            <div class="story-body">
              <h4><i class="bi bi-graph-up-arrow me-2 text-success"></i><%= t('about.growthTitle') %></h4>
              <p><%= t('about.growthText1') %></p>
              <p><%= t('about.growthText2') %></p>
              
              <!-- 数据展示 -->
              <div class="stats-row">
                <div class="row g-3">
                  <div class="col-4">
                    <div class="stat-item">
                      <span class="stat-number">10+</span>
                      <span class="stat-label"><%= t('about.statYears') %></span>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="stat-item">
                      <span class="stat-number">5000+</span>
                      <span class="stat-label"><%= t('about.statCars') %></span>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="stat-item">
                      <span class="stat-number">98%</span>
                      <span class="stat-label"><%= t('about.statSatisfaction') %></span>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- 发展时间线 -->
              <h6 class="fw-bold mt-4 mb-3"><%= t('about.timelineTitle') %></h6>
              <div class="timeline">
                <div class="timeline-item">
                  <strong>2014</strong> - <%= t('about.timeline2014') %>
                </div>
                <div class="timeline-item">
                  <strong>2018</strong> - <%= t('about.timeline2018') %>
                </div>
                <div class="timeline-item">
                  <strong>2022</strong> - <%= t('about.timeline2022') %>
                </div>
                <div class="timeline-item">
                  <strong>2024</strong> - <%= t('about.timeline2024') %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Our Values -->
  <div class="container py-5">
    <div class="section-title centered">
      <h6 class="text-primary fw-bold text-uppercase ls-2 mb-2"><%= t('about.valuesSubtitle') %></h6>
      <h2 class="fw-bold"><%= t('about.valuesTitle') %></h2>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: linear-gradient(135deg, rgba(13,110,253,0.15), rgba(13,110,253,0.05)); color: #0d6efd;">
            <i class="bi bi-shield-check"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value1Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value1Desc') %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: linear-gradient(135deg, rgba(25,135,84,0.15), rgba(25,135,84,0.05)); color: #198754;">
            <i class="bi bi-award"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value2Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value2Desc') %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: linear-gradient(135deg, rgba(255,193,7,0.2), rgba(255,193,7,0.05)); color: #d4a017;">
            <i class="bi bi-car-front"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value3Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value3Desc') %></p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="value-card">
          <div class="value-icon" style="background: linear-gradient(135deg, rgba(111,66,193,0.15), rgba(111,66,193,0.05)); color: #6f42c1;">
            <i class="bi bi-heart-pulse"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('about.value4Title') %></h5>
          <p class="text-muted small mb-0"><%= t('about.value4Desc') %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Services -->
  <div class="container py-5">
    <div class="section-title centered">
      <h6 class="text-primary fw-bold text-uppercase ls-2 mb-2"><%= t('about.businessSubtitle') %></h6>
      <h2 class="fw-bold"><%= t('about.businessTitle') %></h2>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="service-card">
          <div class="d-flex align-items-center mb-3">
            <div style="width:50px;height:50px;background:linear-gradient(135deg, #e7f1ff, #f0f7ff);border-radius:12px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-stars text-primary" style="font-size:1.3rem;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.businessNew') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.businessNewDesc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="service-card">
          <div class="d-flex align-items-center mb-3">
            <div style="width:50px;height:50px;background:linear-gradient(135deg, #e8f5e9, #f1f8e9);border-radius:12px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-car-rear text-success" style="font-size:1.3rem;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.businessUsed') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.businessUsedDesc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="service-card">
          <div class="d-flex align-items-center mb-3">
            <div style="width:50px;height:50px;background:linear-gradient(135deg, #fff3e0, #fff8e1);border-radius:12px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-people text-warning" style="font-size:1.3rem;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.businessWholesale') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.businessWholesaleDesc') %></p>
        </div>
      </div>
    </div>
    
    <!-- 更多服务 -->
    <div class="row g-4 mt-2">
      <div class="col-md-6">
        <div class="service-card" style="border-left-color: #6f42c1;">
          <div class="d-flex align-items-center mb-3">
            <div style="width:50px;height:50px;background:linear-gradient(135deg, #f3e5f5, #f8e8fa);border-radius:12px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-globe text-purple" style="font-size:1.3rem; color: #6f42c1;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.serviceExport') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.serviceExportDesc') %></p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="service-card" style="border-left-color: #dc3545;">
          <div class="d-flex align-items-center mb-3">
            <div style="width:50px;height:50px;background:linear-gradient(135deg, #ffebee, #fce4ec);border-radius:12px;display:flex;align-items:center;justify-content:center;">
              <i class="bi bi-tools text-danger" style="font-size:1.3rem;"></i>
            </div>
            <h5 class="ms-3 mb-0 fw-bold"><%= t('about.serviceAfter') %></h5>
          </div>
          <p class="text-muted mb-0" style="line-height:1.75;"><%= t('about.serviceAfterDesc') %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Map Section -->
  <div class="map-section py-5">
    <div class="container">
      <div class="section-title centered">
        <h6 class="text-primary fw-bold text-uppercase ls-2 mb-2"><%= t('about.visitSubtitle') %></h6>
        <h2 class="fw-bold"><%= t('about.visitTitle') %></h2>
      </div>
      
      <div class="row g-4">
        <div class="col-lg-8">
          <div class="map-container">
            <iframe 
              src="https://uri.amap.com/marker?position=115.8145,32.8906&name=伟德车行&src=mypage&coordinate=gaode&callnative=0" 
              width="100%" 
              height="450" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy">
            </iframe>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="map-info h-100">
            <h5 class="fw-bold mb-4"><i class="bi bi-geo-alt-fill text-primary me-2"></i><%= t('about.locationTitle') %></h5>
            
            <div class="map-info-item">
              <div class="map-info-icon">
                <i class="bi bi-geo-alt"></i>
              </div>
              <div>
                <div class="fw-bold"><%= t('about.addressLabel') %></div>
                <div class="text-muted"><%= t('about.fullAddress') %></div>
              </div>
            </div>
            
            <div class="map-info-item">
              <div class="map-info-icon">
                <i class="bi bi-clock"></i>
              </div>
              <div>
                <div class="fw-bold"><%= t('about.hoursLabel') %></div>
                <div class="text-muted"><%= t('about.hoursValue') %></div>
              </div>
            </div>
            
            <div class="map-info-item">
              <div class="map-info-icon">
                <i class="bi bi-telephone"></i>
              </div>
              <div>
                <div class="fw-bold"><%= t('about.phoneLabel') %></div>
                <div class="text-muted"><%= siteContacts.contact_phone || t('about.phonePlaceholder') %></div>
              </div>
            </div>
            
            <div class="map-info-item">
              <div class="map-info-icon">
                <i class="bi bi-car-front"></i>
              </div>
              <div>
                <div class="fw-bold"><%= t('about.parkingLabel') %></div>
                <div class="text-muted"><%= t('about.parkingValue') %></div>
              </div>
            </div>
            
            <a href="https://uri.amap.com/marker?position=115.8145,32.8906&name=伟德车行&src=mypage&coordinate=gaode&callnative=1" 
               target="_blank" 
               class="btn btn-primary w-100 mt-3">
              <i class="bi bi-map me-2"></i><%= t('about.openMap') %>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact CTA -->
  <div class="container pb-5">
    <div class="contact-footer-card text-center">
      <h3 class="fw-bold mb-2"><i class="bi bi-telephone-fill me-2"></i><%= t('about.contactTitle') %></h3>
      <p class="mb-4 opacity-75" style="font-size: 1.1rem;"><%= t('about.welcome') %></p>
      <div class="row justify-content-center g-4 text-start">
        <% if (siteContacts.contact_phone) { %>
        <div class="col-md-4">
          <div class="info-item">
            <i class="bi bi-telephone"></i>
            <div>
              <div class="small opacity-75"><%= t('about.phoneLabel') %></div>
              <div><a href="tel:<%= siteContacts.contact_phone %>"><%= siteContacts.contact_phone %></a></div>
            </div>
          </div>
        </div>
        <% } %>
        <% if (siteContacts.contact_address) { %>
        <div class="col-md-4">
          <div class="info-item">
            <i class="bi bi-geo-alt-fill"></i>
            <div>
              <div class="small opacity-75"><%= t('about.addressLabel') %></div>
              <div><%= siteContacts.contact_address %></div>
            </div>
          </div>
        </div>
        <% } %>
        <div class="col-md-4">
          <div class="info-item">
            <i class="bi bi-clock"></i>
            <div>
              <div class="small opacity-75"><%= t('about.hoursLabel') %></div>
              <div><%= t('about.hoursValue') %></div>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-4">
        <a href="/contact?lang=<%= lang %>" class="btn btn-light btn-lg px-5">
          <i class="bi bi-chat-dots me-2"></i><%= t('about.ctaButton') %>
        </a>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-light py-4 mt-auto">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-5">
          <p class="mb-1"><i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %> - <%= t('siteSlogan') %></p>
          <p class="text-muted small mb-0">&copy; 2026 <%= t('siteName') %>. <%= t('footer.copyright') %>.</p>
        </div>
        <div class="col-md-7 text-md-end">
          <a href="/" class="text-muted small"><%= t('nav.home') %></a>
          <span class="text-muted mx-2">|</span>
          <a href="/contact?lang=<%= lang %>" class="text-muted small"><%= t('nav.contact') %></a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
