<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/cars"><i class="bi bi-car-front me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Cars' : '车辆管理' %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/cars/create"><i class="bi bi-plus-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Add Car' : '添加车辆' %></a>
          </li>
          <% if (user && user.role === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link" href="/admin/review"><i class="bi bi-check-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Review' : '审核' %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/settings"><i class="bi bi-gear me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Settings' : '网站设置' %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/users"><i class="bi bi-people me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Users' : '用户管理' %></a>
          </li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'User' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <h2 class="mb-4"><%= title %></h2>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="card border-primary shadow-sm">
          <div class="card-body text-center py-4">
            <i class="bi bi-car-front text-primary" style="font-size: 2.5rem;"></i>
            <h5 class="mt-2"><%= t('nav.admin') === 'Admin Panel' ? 'Total Cars' : '车辆总数' %></h5>
            <h2 class="text-primary fw-bold"><%= totalCars %></h2>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-success shadow-sm">
          <div class="card-body text-center py-4">
            <i class="bi bi-check-circle text-success" style="font-size: 2.5rem;"></i>
            <h5 class="mt-2"><%= t('nav.admin') === 'Admin Panel' ? 'Active Listings' : '在售车辆' %></h5>
            <h2 class="text-success fw-bold"><%= activeCars %></h2>
          </div>
        </div>
      </div>
      <% if (user && user.role === 'admin') { %>
      <div class="col-md-3">
        <div class="card border-info shadow-sm">
          <div class="card-body text-center py-4">
            <i class="bi bi-people text-info" style="font-size: 2.5rem;"></i>
            <h5 class="mt-2"><%= t('nav.admin') === 'Admin Panel' ? 'Users' : '用户' %></h5>
            <h2 class="text-info fw-bold"><%= totalUsers %></h2>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-warning shadow-sm">
          <div class="card-body text-center py-4">
            <i class="bi bi-clock-history text-warning" style="font-size: 2.5rem;"></i>
            <h5 class="mt-2"><%= t('nav.admin') === 'Admin Panel' ? 'Pending Review' : '待审核' %></h5>
            <h2 class="text-warning fw-bold"><%= pendingCars %></h2>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <div class="card shadow-sm">
          <div class="card-body text-center py-5">
            <i class="bi bi-plus-circle text-primary" style="font-size: 3rem;"></i>
            <h5 class="mt-3"><%= t('nav.admin') === 'Admin Panel' ? 'Add New Car' : '添加新车' %></h5>
            <a href="/admin/cars/create" class="btn btn-primary mt-2">
              <i class="bi bi-plus-lg me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Create' : '创建' %>
            </a>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card shadow-sm">
          <div class="card-body text-center py-5">
            <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
            <h5 class="mt-3"><%= t('nav.admin') === 'Admin Panel' ? 'Review Cars' : '审核车辆' %></h5>
            <a href="/admin/review" class="btn btn-warning mt-2">
              <i class="bi bi-clock-history me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Review' : '去审核' %>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
