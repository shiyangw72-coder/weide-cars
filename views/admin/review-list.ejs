<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin?lang=<%= lang %>"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars?lang=<%= lang %>"><i class="bi bi-car-front me-1"></i><%= t('admin.cars') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars/create?lang=<%= lang %>"><i class="bi bi-plus-circle me-1"></i><%= t('admin.addCar') %></a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/review?lang=<%= lang %>"><i class="bi bi-check-circle me-1"></i><%= t('admin.review') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users?lang=<%= lang %>"><i class="bi bi-people me-1"></i><%= t('admin.users') %></a></li>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'User' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0"><%= title %></h2>
    </div>

    <% if (cars && cars.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>ID</th>
            <th><%= t('admin.brand') %></th>
            <th><%= t('admin.model') %></th>
            <th><%= t('car.registrationYear') %></th>
            <th><%= t('admin.displacement') %></th>
            <th><%= t('admin.costCNY') %></th>
            <th><%= t('admin.submittedBy') %></th>
            <th><%= t('admin.submittedAt') %></th>
            <th><%= t('admin.actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% cars.forEach(function(car) { %>
          <tr>
            <td><%= car.id %></td>
            <td><strong><%= car.brand %></strong></td>
            <td><%= car.model %></td>
            <td><%= car.year || '-' %></td>
            <td><%= car.displacement || '-' %></td>
            <td><%= car.cost_price ? '¥' + Number(car.cost_price).toLocaleString() : '-' %></td>
            <td><small><%= car.creator_name || 'Unknown' %></small></td>
            <td><small><%= car.created_at %></small></td>
            <td>
              <a href="/admin/review/<%= car.id %>?lang=<%= lang %>" class="btn btn-sm btn-warning">
                <i class="bi bi-check-circle me-1"></i><%= t('admin.review') %>
              </a>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
      <h4 class="mt-3 text-muted"><%= t('admin.noPending') %></h4>
    </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
