<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars"><i class="bi bi-car-front me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Cars' : '车辆管理' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars/create"><i class="bi bi-plus-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Add Car' : '添加车辆' %></a></li>
          <% if (user && user.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/admin/review"><i class="bi bi-check-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Review' : '审核' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users"><i class="bi bi-people me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Users' : '用户管理' %></a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'User' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <h2 class="mb-4"><%= title %></h2>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (user && user.role !== 'admin') { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      <%= t('nav.admin') === 'Admin Panel' ? 'Note: New cars require admin review. You can enter cost price (CNY) and details, but final price (USD) will be set by admin.' : '提示：新增车辆需要主账号审核。您可以填写成本价（人民币）和详细信息，最终售价（美金）由主账号审核后设定。' %>
    </div>
    <% } %>

    <form method="POST" action="/admin/cars/<%= car && car.id ? 'edit/' + car.id : 'create' %>" enctype="multipart/form-data">
      <input type="hidden" name="lang" value="<%= lang %>">

      <div class="row g-4">
        <div class="col-md-6">
          <div class="card shadow-sm">
            <div class="card-header"><%= t('nav.admin') === 'Admin Panel' ? 'Basic Information' : '基本信息' %></div>
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Brand *' : '品牌 *' %></label>
                <input type="text" name="brand" class="form-control" value="<%= car ? car.brand : '' %>" required>
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Model *' : '型号 *' %></label>
                <input type="text" name="model" class="form-control" value="<%= car ? car.model : '' %>" required>
              </div>
              <div class="row">
                <div class="col-6 mb-3">
                  <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Year *' : '年份 *' %></label>
                  <input type="number" name="year" class="form-control" value="<%= car ? car.year : '' %>" min="1990" max="2030" required>
                </div>
                <div class="col-6 mb-3">
                  <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Mileage (km) *' : '里程 (km) *' %></label>
                  <input type="number" name="mileage" class="form-control" value="<%= car ? car.mileage : '' %>" min="0" required>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Cost Price (CNY) *' : '成本价（人民币） *' %></label>
                <input type="number" name="cost_price" class="form-control" value="<%= car ? car.cost_price : '' %>" step="0.01" min="0" required>
              </div>
              <% if (user && user.role === 'admin') { %>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Sale Price (USD)' : '售价（美金）' %></label>
                <input type="number" name="price" class="form-control" value="<%= car ? car.price : '' %>" step="0.01" min="0">
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card shadow-sm">
            <div class="card-header"><%= t('nav.admin') === 'Admin Panel' ? 'Details' : '详细信息' %></div>
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Category *' : '车辆分类 *' %></label>
                <select name="category" class="form-select" required>
                  <option value=""><%= t('nav.admin') === 'Admin Panel' ? 'Select...' : '请选择...' %></option>
                  <option value="SUV" <%= car && car.category === 'SUV' ? 'selected' : '' %>>🚙 SUV</option>
                  <option value="sedan" <%= car && car.category === 'sedan' ? 'selected' : '' %>>🚗 <%= t('nav.admin') === 'Admin Panel' ? 'Sedan' : '轿车' %></option>
                  <option value="truck" <%= car && car.category === 'truck' ? 'selected' : '' %>>🚛 <%= t('nav.admin') === 'Admin Panel' ? 'Truck' : '卡车' %></option>
                  <option value="van" <%= car && car.category === 'van' ? 'selected' : '' %>>🚚 <%= t('nav.admin') === 'Admin Panel' ? 'Van/Cargo' : '货车' %></option>
                  <option value="ev" <%= car && car.category === 'ev' ? 'selected' : '' %>>⚡ <%= t('nav.admin') === 'Admin Panel' ? 'EV/New Energy' : '新能源' %></option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Color *' : '颜色 *' %></label>
                <input type="text" name="color" class="form-control" value="<%= car ? car.color : '' %>" required>
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Fuel Type *' : '燃料类型 *' %></label>
                <select name="fuel_type" class="form-select" required>
                  <option value=""><%= t('nav.admin') === 'Admin Panel' ? 'Select...' : '请选择...' %></option>
                  <option value="Gasoline" <%= car && car.fuel_type === 'Gasoline' ? 'selected' : '' %>><%= t('nav.admin') === 'Admin Panel' ? 'Gasoline' : '汽油' %></option>
                  <option value="Diesel" <%= car && car.fuel_type === 'Diesel' ? 'selected' : '' %>><%= t('nav.admin') === 'Admin Panel' ? 'Diesel' : '柴油' %></option>
                  <option value="Electric" <%= car && car.fuel_type === 'Electric' ? 'selected' : '' %>><%= t('nav.admin') === 'Admin Panel' ? 'Electric' : '电动' %></option>
                  <option value="Hybrid" <%= car && car.fuel_type === 'Hybrid' ? 'selected' : '' %>><%= t('nav.admin') === 'Admin Panel' ? 'Hybrid' : '混动' %></option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Transmission *' : '变速箱 *' %></label>
                <select name="transmission" class="form-select" required>
                  <option value=""><%= t('nav.admin') === 'Admin Panel' ? 'Select...' : '请选择...' %></option>
                  <option value="Automatic" <%= car && car.transmission === 'Automatic' ? 'selected' : '' %>><%= t('nav.admin') === 'Admin Panel' ? 'Automatic' : '自动挡' %></option>
                  <option value="Manual" <%= car && car.transmission === 'Manual' ? 'selected' : '' %>><%= t('nav.admin') === 'Admin Panel' ? 'Manual' : '手动挡' %></option>
                  <option value="CVT" <%= car && car.transmission === 'CVT' ? 'selected' : '' %>>CVT</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Engine Displacement (L) *' : '排量 (L) *' %></label>
                <input type="text" name="displacement" class="form-control" value="<%= car ? car.displacement : '' %>" placeholder="<%= t('nav.admin') === 'Admin Panel' ? 'e.g. 1.5L' : '例如 1.5L' %>" required>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-header"><%= t('nav.admin') === 'Admin Panel' ? 'Description & Media' : '描述和媒体' %></div>
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Detailed Description *' : '详细描述 *' %></label>
                <textarea name="description" class="form-control" rows="4" required><%= car ? car.description : '' %></textarea>
              </div>

              <% if (!car || !car.id) { %>
              <div class="row">
                <div class="col-md-8 mb-3">
                  <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Vehicle Images (9 required) *' : '车辆图片（需9张） *' %></label>
                  <input type="file" name="images" class="form-control" id="imagesInput" multiple accept="image/*" required>
                  <small class="text-muted"><%= t('nav.admin') === 'Admin Panel' ? 'Please upload exactly 9 images.' : '请上传 9 张车辆图片。' %></small>
                  <div class="d-flex flex-wrap gap-2 mt-2" id="imagesPreview"></div>
                </div>
                <div class="col-md-4 mb-3">
                  <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Vehicle Video (1 required) *' : '车辆视频（需1个） *' %></label>
                  <input type="file" name="video" class="form-control" id="videoInput" accept="video/*" required>
                  <small class="text-danger"><%= t('nav.admin') === 'Admin Panel' ? 'Must include a full walk-around and entering the cockpit.' : '视频必须包含围绕车身拍一圈并进入驾驶舱。' %></small>
                  <div class="mt-2" id="videoPreview"></div>
                </div>
              </div>
              <% } else { %>
              <% 
                let existingImages = 0;
                let existingVideos = 0;
                if (car.media) {
                  car.media.forEach(m => { if (m.file_type === 'image') existingImages++; if (m.file_type === 'video') existingVideos++; });
                }
              %>
              <div class="alert alert-light border">
                <i class="bi bi-images me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'Current media:' : '当前媒体：' %> <%= existingImages %> <%= t('nav.admin') === 'Admin Panel' ? 'images' : '张图片' %>, <%= existingVideos %> <%= t('nav.admin') === 'Admin Panel' ? 'video' : '个视频' %>.
                <%= t('nav.admin') === 'Admin Panel' ? 'Max 9 images and 1 video total.' : '图片最多 9 张，视频最多 1 个。' %>
              </div>
              <% if (car.media && car.media.length > 0) { %>
              <div class="mt-2 mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Existing Media' : '已有媒体' %></label>
                <div class="row g-2">
                  <% car.media.forEach(function(item) { %>
                  <div class="col-2 position-relative">
                    <div class="border rounded p-1 text-center" style="height: 100px; overflow: hidden;">
                      <% if (item.file_type === 'image') { %>
                        <img src="/media/<%= item.id %>" style="max-width:100%; max-height:80px;">
                      <% } else { %>
                        <video src="/media/<%= item.id %>" style="max-width:100%; max-height:80px;"></video>
                      <% } %>
                    </div>
                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0" onclick="deleteMedia(<%= item.id %>)">&times;</button>
                  </div>
                  <% }); %>
                </div>
              </div>
              <% } %>
              <div class="row">
                <div class="col-md-8 mb-3">
                  <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Add Images (max 9 total)' : '添加图片（最多9张）' %></label>
                  <input type="file" name="new_images" class="form-control" id="newImagesInput" multiple accept="image/*">
                  <small class="text-muted"><%= t('nav.admin') === 'Admin Panel' ? 'You can add up to ' + (9 - existingImages) + ' more images.' : '还可添加最多 ' + (9 - existingImages) + ' 张图片。' %></small>
                  <div class="d-flex flex-wrap gap-2 mt-2" id="newImagesPreview"></div>
                </div>
                <div class="col-md-4 mb-3">
                  <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Add Video (max 1 total)' : '添加视频（最多1个）' %></label>
                  <input type="file" name="new_video" class="form-control" id="newVideoInput" accept="video/*" <%= existingVideos >= 1 ? 'disabled' : '' %>>
                  <small class="text-danger"><%= t('nav.admin') === 'Admin Panel' ? 'Must include a full walk-around and entering the cockpit.' : '视频必须包含围绕车身拍一圈并进入驾驶舱。' %></small>
                  <div class="mt-2" id="newVideoPreview"></div>
                </div>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <% if (car && car.id && user && user.role === 'admin') { %>
        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-header"><%= t('nav.admin') === 'Admin Panel' ? 'Status' : '状态' %></div>
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Car Status' : '车辆状态' %></label>
                <select name="status" class="form-select">
                  <option value="active" <%= car.status === 'active' ? 'selected' : '' %>><%= t('car.forSale') %></option>
                  <option value="sold" <%= car.status === 'sold' ? 'selected' : '' %>><%= t('car.sold') %></option>
                </select>
              </div>
            </div>
          </div>
        </div>
        <% } %>

        <% if (user && user.role === 'admin') { %>
        <div class="col-12">
          <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white">
              <i class="bi bi-telephone me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'Contact Information (Optional)' : '联系方式（选填）' %>
            </div>
            <div class="card-body">
              <p class="text-muted small mb-3">
                <i class="bi bi-info-circle me-1"></i><%= t('nav.admin') === 'Admin Panel'
                  ? 'If set, this car\'s detail page will display these contacts instead of the global site contacts.'
                  : '若设置，则该车辆详情页优先显示此联系方式；留空则显示网站全局联系方式。' %>
              </p>
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label"><i class="bi bi-wechat me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'WeChat' : '微信' %></label>
                  <input type="text" name="contact_wechat" class="form-control" value="<%= car ? (car.contact_wechat || '') : '' %>" placeholder="<%= t('nav.admin') === 'Admin Panel' ? 'WeChat ID' : '微信号' %>">
                </div>
                <div class="col-md-4">
                  <label class="form-label"><i class="bi bi-whatsapp me-1"></i>WhatsApp</label>
                  <input type="text" name="contact_whatsapp" class="form-control" value="<%= car ? (car.contact_whatsapp || '') : '' %>" placeholder="+86 138 xxxx xxxx">
                </div>
                <div class="col-md-4">
                  <label class="form-label"><i class="bi bi-envelope me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Email' : '邮箱' %></label>
                  <input type="email" name="contact_email" class="form-control" value="<%= car ? (car.contact_email || '') : '' %>" placeholder="example@mail.com">
                </div>
              </div>
            </div>
          </div>
        </div>
        <% } %>
      </div>

      <div class="mt-4">
        <div class="card shadow-sm border-warning">
          <div class="card-header bg-warning text-dark">
            <i class="bi bi-translate me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'Auto Translation' : '自动翻译' %>
          </div>
          <div class="card-body">
            <p class="text-muted small mb-3">
              <i class="bi bi-info-circle me-1"></i>
              <%= t('nav.admin') === 'Admin Panel'
                ? 'Translate car info (brand, model, description, color) to English and French. Chinese is used as the source.'
                : '将车辆信息（品牌、型号、描述、颜色）从中文翻译为英文和法文。' %>
            </p>
            <% if (car && car.id) { %>
            <form method="POST" action="/admin/cars/translate/<%= car.id %>?lang=<%= lang %>" id="translateForm" style="display:inline;">
              <input type="hidden" name="from_lang" value="zh">
              <button type="submit" class="btn btn-warning px-4"
                onclick="return confirm('<%= t('nav.admin') === "Admin Panel" ? "Translate car info to all languages?" : "确定将车辆信息翻译为所有语言？" %>')">
                <i class="bi bi-translate me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Translate' : '一键翻译' %>
              </button>
            </form>
            <% } else { %>
            <button type="button" class="btn btn-warning px-4" id="ajaxTranslateBtn" onclick="translateFields()">
              <i class="bi bi-translate me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Translate' : '一键翻译' %>
            </button>
            <% } %>
            <span class="text-muted ms-2 small" id="translateStatus">→ EN / FR</span>

            <% 
            let trans = {};
            if (car && car.translations) {
              try { trans = JSON.parse(car.translations); } catch(e) {}
            }
            %>
            <div class="mt-3" id="translationResults">
              <% ['en','fr'].forEach(function(tlang) { %>
                <% const langLabel = tlang === 'en' ? '🇬🇧 English' : '🇫🇷 Français'; %>
                <div class="card mb-3 border-light translation-lang-card" data-lang="<%= tlang %>">
                  <div class="card-header bg-light fw-bold"><%= langLabel %></div>
                  <div class="card-body row g-3">
                    <div class="col-md-3">
                      <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Brand' : '品牌' %></label>
                      <input type="text" class="form-control" name="trans_<%= tlang %>_brand" value="<%= trans[tlang] && trans[tlang].brand || '' %>">
                    </div>
                    <div class="col-md-3">
                      <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Model' : '型号' %></label>
                      <input type="text" class="form-control" name="trans_<%= tlang %>_model" value="<%= trans[tlang] && trans[tlang].model || '' %>">
                    </div>
                    <div class="col-md-3">
                      <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Color' : '颜色' %></label>
                      <input type="text" class="form-control" name="trans_<%= tlang %>_color" value="<%= trans[tlang] && trans[tlang].color || '' %>">
                    </div>
                    <div class="col-md-12">
                      <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Description' : '描述' %></label>
                      <textarea class="form-control" name="trans_<%= tlang %>_description" rows="2"><%= trans[tlang] && trans[tlang].description || '' %></textarea>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4" id="submitBtn">
          <i class="bi bi-check-lg me-1"></i><%= car && car.id ? (t('nav.admin') === 'Admin Panel' ? 'Update' : '更新') : (t('nav.admin') === 'Admin Panel' ? 'Create' : '创建') %>
        </button>
        <a href="/admin/cars" class="btn btn-outline-secondary px-4">
          <i class="bi bi-x-lg me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Cancel' : '取消' %>
        </a>
      </div>
    </form>
  </div>

  <form id="deleteMediaForm" method="POST" style="display:none;">
    <input type="hidden" name="_method" value="DELETE">
  </form>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  // ===== 累积式文件选择（支持一张张添加）=====
  function setupAccumulateInput(inputId, previewId, type) {
    var input = document.getElementById(inputId);
    var preview = document.getElementById(previewId);
    if (!input || !preview) return;

    // 用 DataTransfer 保存已选文件
    var accumulatedFiles = [];

    input.addEventListener('change', function() {
      var newFiles = this.files;
      if (!newFiles || newFiles.length === 0) return;

      // 追加到累积列表
      for (var i = 0; i < newFiles.length; i++) {
        accumulatedFiles.push(newFiles[i]);
      }

      // 限制数量
      var maxFiles = (type === 'image') ? 9 : 1;
      if (accumulatedFiles.length > maxFiles) {
        accumulatedFiles = accumulatedFiles.slice(0, maxFiles);
        alert((type === 'image' ? '图片' : '视频') + '最多' + maxFiles + '个，已自动截取前' + maxFiles + '个');
      }

      // 更新预览
      renderPreview(preview, accumulatedFiles, type);

      // 把累积的文件重新写回 input（这样提交时能带上所有文件）
      var dt = new DataTransfer();
      for (var j = 0; j < accumulatedFiles.length; j++) {
        dt.items.add(accumulatedFiles[j]);
      }
      input.files = dt.files;
    });
  }

  function renderPreview(container, files, type) {
    container.innerHTML = '';
    for (var i = 0; i < files.length; i++) {
      (function(f, idx) {
        if (type === 'image' && f.type.startsWith('image/')) {
          var reader = new FileReader();
          reader.onload = function(e) {
            var wrap = document.createElement('div');
            wrap.className = 'position-relative d-inline-block';
            wrap.style.cssText = 'margin:2px;';
            var img = document.createElement('img');
            img.src = e.target.result;
            img.className = 'border rounded';
            img.style.cssText = 'width:80px;height:80px;object-fit:cover;display:block;';
            img.title = f.name;
            wrap.appendChild(img);
            // 删除按钮
            var rmBtn = document.createElement('button');
            rmBtn.type = 'button';
            rmBtn.className = 'btn btn-sm btn-danger position-absolute';
            rmBtn.style.cssText = 'top:-5px;right:-5px;width:20px;height:20px;padding:0;font-size:12px;line-height:20px;border-radius:50%;';
            rmBtn.innerHTML = '&times;';
            rmBtn.onclick = function() { removeFile(inputId, previewId, type, idx); };
            wrap.appendChild(rmBtn);
            container.appendChild(wrap);
          };
          reader.readAsDataURL(f);
        } else if (type === 'video' && f.type.startsWith('video/')) {
          var vid = document.createElement('video');
          vid.src = URL.createObjectURL(f);
          vid.controls = true;
          vid.style.cssText = 'width:200px;max-height:120px;display:block;margin:2px;';
          vid.title = f.name;
          container.appendChild(vid);
        }
      })(files[i], i);
    }
    // 文件计数
    var count = document.createElement('div');
    count.id = previewId + '_count';
    count.className = 'badge bg-success mt-1';
    count.textContent = '\u2705 \u5df2\u9009\u62e9 ' + files.length + ' \u4e2a\u6587\u4ef6';
    container.appendChild(count);
  }

  // 从累积列表中移除某个文件
  function removeFile(inputId, previewId, type, idx) {
    var input = document.getElementById(inputId);
    // 需要从全局 accumulatedFiles 中移除，这里通过重新读取实现
    // 简化方案：清空 input 让用户重选（DataTransfer 在闭包外不可直接访问）
    input.value = '';
    var preview = document.getElementById(previewId);
    if (preview) preview.innerHTML = '<span class=\"text-muted small\">\u5df2\u6e05\u7a7a，\u8bf7\u91cd\u65b0\u9009\u62e9</span>';
  }

  setupAccumulateInput('imagesInput', 'imagesPreview', 'image');
  setupAccumulateInput('videoInput', 'videoPreview', 'video');
  setupAccumulateInput('newImagesInput', 'newImagesPreview', 'image');
  setupAccumulateInput('newVideoInput', 'newVideoPreview', 'video');

    // ===== 表单提交处理（手动fetch提交）=====
  (function() {
    var btn = document.getElementById("submitBtn");
    if (!btn) return;
    var formEl = document.querySelector('form[enctype="multipart/form-data"]');
    if (!formEl) return;

    btn.addEventListener("click", function(e) {
      e.preventDefault();
      e.stopPropagation();
      btn.disabled = true;
      btn.innerHTML = "<span class=\"spinner-border spinner-border-sm me-1\"></span>上传中...";
      var fd = new FormData(formEl);
      fetch(formEl.action, { method: "POST", body: fd })
        .then(function(resp) {
          if (resp.ok || resp.status === 302 || resp.redirected) {
            window.location.href = "/admin/cars";
          } else {
            return resp.text().then(function(html) {
              var match = html.match(/alert-danger[^>]*>([^<]*)/);
              var errMsg = match ? match[1] : ("Server error " + resp.status);
              alert("保存失败: " + errMsg);
              btn.disabled = false;
              btn.innerHTML = "<i class=\"bi bi-check-lg me-1\"></i>" + (formEl.action.includes('create') ? '创建' : '更新');
            });
          }
        })
        .catch(function(err) {
          alert("提交失败: " + err.message);
          btn.disabled = false;
          btn.innerHTML = "<i class=\"bi bi-check-lg me-1\"></i>" + (formEl.action.includes('create') ? '创建' : '更新');
        });
    });
  })();;

  document.getElementById('translateForm') && document.getElementById('translateForm').addEventListener('submit', function(e) {
    const btn = this.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + (btn.innerText.includes('Translate') ? 'Translating...' : '翻译中...');
  });
  function translateFields() {
    const btn = document.getElementById('ajaxTranslateBtn');
    const status = document.getElementById('translateStatus');
    const brand = document.querySelector('input[name="brand"]')?.value || '';
    const model = document.querySelector('input[name="model"]')?.value || '';
    const color = document.querySelector('input[name="color"]')?.value || '';
    const description = document.querySelector('textarea[name="description"]')?.value || '';
    if (!brand || !model || !description) {
      alert('<%= t("nav.admin") === "Admin Panel" ? "Please fill brand, model and description first" : "请先填写品牌、型号和描述" %>');
      return;
    }
    btn.disabled = true;
    status.textContent = '<%= t("nav.admin") === "Admin Panel" ? "Translating..." : "翻译中..." %>';
    const params = new URLSearchParams();
    params.append('brand', brand);
    params.append('model', model);
    params.append('color', color);
    params.append('description', description);
    params.append('from_lang', 'zh');
    fetch('/admin/cars/translate-fields', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: params
    })
    .then(r => r.json())
    .then(data => {
      if (data.error) throw new Error(data.error);
      for (const [lang, fields] of Object.entries(data.translations)) {
        for (const [field, value] of Object.entries(fields)) {
          const input = document.querySelector('[name="trans_' + lang + '_' + field + '"]');
          if (input) input.value = value;
        }
      }
      status.textContent = '<%= t("nav.admin") === "Admin Panel" ? "Translation complete" : "翻译完成" %>';
    })
    .catch(err => {
      alert('<%= t("nav.admin") === "Admin Panel" ? "Translation failed: " : "翻译失败：" %>' + err.message);
      status.textContent = '→ EN / FR';
    })
    .finally(() => {
      btn.disabled = false;
    });
  }
  function deleteMedia(mediaId) {
    if (confirm('<%= t("nav.admin") === "Admin Panel" ? "Delete this media?" : "确定删除此媒体？" %>')) {
      fetch('/admin/cars/media/delete/' + mediaId, { method: 'POST' })
        .then(r => r.json())
        .then(d => { if (d.success) location.reload(); });
    }
  }
  </script>
</body>
</html>
