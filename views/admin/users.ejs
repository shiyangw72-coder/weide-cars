<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('admin.usersTitle') %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin?lang=<%= lang %>"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars?lang=<%= lang %>"><i class="bi bi-car-front me-1"></i><%= t('admin.cars') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars/create?lang=<%= lang %>"><i class="bi bi-plus-circle me-1"></i><%= t('admin.addCar') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/review?lang=<%= lang %>"><i class="bi bi-check-circle me-1"></i><%= t('admin.review') %></a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/users?lang=<%= lang %>"><i class="bi bi-people me-1"></i><%= t('admin.users') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/settings?lang=<%= lang %>"><i class="bi bi-gear me-1"></i><%= t('admin.settings') %></a></li>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'Admin' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0"><%= t('admin.usersTitle') %></h2>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
        <i class="bi bi-person-plus me-1"></i><%= t('admin.createUser') %>
      </button>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="card">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th><%= t('admin.seq') %></th>
              <th><%= t('admin.username') %></th>
              <th><%= t('admin.displayName') %></th>
              <th><%= t('admin.role') %></th>
              <th><%= t('admin.carCount') %></th>
              <th><%= t('admin.createdAt') %></th>
              <th><%= t('admin.actions') %></th>
            </tr>
          </thead>
          <tbody>
            <% if (users && users.length > 0) { %>
              <% users.forEach(function(u, idx) {
                   var carCount = u.car_count ? parseInt(u.car_count) : 0;
                   var roleLabel = u.role === 'admin' ? t('admin.admin') : t('admin.subAccount');
                   var roleClass = u.role === 'admin' ? 'bg-danger' : 'bg-secondary';
                   var createdAt = u.created_at;
                   var dateStr = '-';
                   if (createdAt) {
                     try {
                       var d = new Date(createdAt);
                       dateStr = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
                     } catch(e) { dateStr = '-'; }
                   }
              %>
              <tr>
                <td><%= idx + 1 %></td>
                <td><strong><%= u.username || '' %></strong></td>
                <td><%= u.display_name || '-' %></td>
                <td><span class="badge <%= roleClass %>"><%= roleLabel %></span></td>
                <td><span class="badge bg-info"><%= carCount %></span></td>
                <td><small class="text-muted"><%= dateStr %></small></td>
                <td>
                  <% if (u.role !== 'admin' && u.id !== (user && user.id)) { %>
                    <form method="POST" action="/admin/users/delete/<%= u.id %>?lang=<%= lang %>" style="display:inline;" onsubmit="return confirm('<%= t("admin.deleteUserConfirm") %>');">
                      <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  <%= t('admin.noSubAccounts') %>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-3 text-muted small">
      <%= t('admin.subAccountDesc') %>
    </div>
  </div>

  <!-- Create User Modal -->
  <div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <form method="POST" action="/admin/users/create?lang=<%= lang %>">
          <div class="modal-header bg-primary text-white">
            <h5 class="modal-title"><%= t('admin.newSubAccount') %></h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label"><%= t('admin.username') %> *</label>
              <input type="text" name="username" class="form-control" required minlength="3">
            </div>
            <div class="mb-3">
              <label class="form-label"><%= t('admin.password') %> *</label>
              <input type="password" name="password" class="form-control" required minlength="6">
            </div>
            <div class="mb-3">
              <label class="form-label"><%= t('admin.displayName') %></label>
              <input type="text" name="display_name" class="form-control">
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= t('admin.cancel') %></button>
            <button type="submit" class="btn btn-primary"><%= t('admin.confirmCreate') %></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
