<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars"><i class="bi bi-car-front me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Cars' : '车辆管理' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars/create"><i class="bi bi-plus-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Add Car' : '添加车辆' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/review"><i class="bi bi-check-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Review' : '审核' %></a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/settings"><i class="bi bi-gear me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Settings' : '网站设置' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users"><i class="bi bi-people me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Users' : '用户管理' %></a></li>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'User' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <% if (success) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="card shadow-sm">
          <div class="card-header bg-primary text-white">
            <i class="bi bi-gear me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'Website Settings' : '网站设置' %>
          </div>
          <div class="card-body">
            <p class="text-muted small mb-4">
              <i class="bi bi-info-circle me-1"></i>
              <%= t('nav.admin') === 'Admin Panel'
                ? 'Global contact info will be displayed at the bottom of the homepage and on each car listing page. You can also set per-car contact info when adding/editing a car.'
                : '全局联系方式会显示在首页底部和各车辆详情页。在添加/编辑车源时，也可以为单个车源单独设置联系方式（优先显示单车辆联系方式）。' %>
            </p>

            <form method="POST" action="/admin/settings" enctype="multipart/form-data">
              <input type="hidden" name="lang" value="<%= lang %>">

              <h5 class="mb-3"><i class="bi bi-globe me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'Global Contact Information' : '全局联系方式' %></h5>

              <div class="row g-3 mb-4">
                <div class="col-md-6">
                  <label class="form-label">
                    <i class="bi bi-wechat me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'WeChat ID' : '微信号' %>
                  </label>
                  <input type="text" name="contact_wechat" class="form-control" value="<%= settings.contact_wechat || '' %>" placeholder="<%= t('nav.admin') === 'Admin Panel' ? 'WeChat ID' : '微信号' %>">
                </div>
                <div class="col-md-6">
                  <label class="form-label">
                    <i class="bi bi-whatsapp me-1"></i>WhatsApp
                  </label>
                  <input type="text" name="contact_whatsapp" class="form-control" value="<%= settings.contact_whatsapp || '' %>" placeholder="+86 138 xxxx xxxx">
                </div>
                <div class="col-md-6">
                  <label class="form-label">
                    <i class="bi bi-envelope me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Email' : '邮箱' %>
                  </label>
                  <input type="email" name="contact_email" class="form-control" value="<%= settings.contact_email || '' %>" placeholder="example@mail.com">
                </div>
                <div class="col-md-6">
                  <label class="form-label">
                    <i class="bi bi-telephone me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Phone' : '电话' %>
                  </label>
                  <input type="text" name="contact_phone" class="form-control" value="<%= settings.contact_phone || '' %>" placeholder="+86 138 xxxx xxxx">
                </div>
                <div class="col-12">
                  <label class="form-label">
                    <i class="bi bi-geo-alt me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Address' : '公司地址' %>
                  </label>
                  <input type="text" name="contact_address" class="form-control" value="<%= settings.contact_address || '' %>" placeholder="<%= t('nav.admin') === 'Admin Panel' ? 'Company address' : '填写公司/门店地址' %>">
                </div>
              </div>

              <hr>
              <h6 class="mb-3"><i class="bi bi-qr-code me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'WeChat QR Code' : '微信二维码图片' %></h6>
              <div class="row g-3 align-items-center mb-4">
                <div class="col-md-4">
                  <% if (settings.wechat_qr_image) { %>
                  <div class="text-center">
                    <img src="data:image/png;base64,<%- settings.wechat_qr_image %>" alt="WeChat QR" class="rounded" style="max-width: 160px; max-height: 160px; border: 2px solid #dee2e6;">
                    <div class="small text-muted mt-1">当前二维码</div>
                  </div>
                  <% } else { %>
                  <div class="text-center text-muted border rounded py-4" style="max-width: 160px;">
                    <i class="bi bi-image" style="font-size: 2rem;"></i>
                    <div class="small mt-1">暂无二维码</div>
                  </div>
                  <% } %>
                </div>
                <div class="col-md-8">
                  <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Upload QR Code (JPG/PNG, max 5MB)' : '上传微信二维码（JPG/PNG，最大5MB）' %></label>
                  <input type="file" name="wechat_qr_image" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp">
                  <div class="form-text"><%= t('nav.admin') === 'Admin Panel' ? 'Leave empty to keep current QR code' : '不选择则保留当前二维码' %></div>
                </div>
              </div>

              <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-primary px-4">
                  <i class="bi bi-check-lg me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Save Settings' : '保存设置' %>
                </button>
              </div>
            </form>
          </div>
        </div>

        <div class="card shadow-sm mt-4">
          <div class="card-header bg-secondary text-white">
            <i class="bi bi-lightbulb me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'Contact Display Logic' : '联系方式显示逻辑' %>
          </div>
          <div class="card-body">
            <ul class="mb-0">
              <li><%= t('nav.admin') === 'Admin Panel' ? 'If a car has its own contact info set, that will be displayed on the car detail page.' : '如果车辆有单独设置的联系方式，则该车辆详情页优先显示单车辆联系方式。' %></li>
              <li><%= t('nav.admin') === 'Admin Panel' ? 'The homepage footer always displays the global contact settings.' : '首页底部始终显示全局联系方式。' %></li>
              <li><%= t('nav.admin') === 'Admin Panel' ? 'Only the main admin account can modify contact information. Sub-accounts cannot edit contact fields.' : '只有主账号可以修改联系方式，子账号无法编辑联系方式字段。' %></li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
