<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a></li>
          <% if (user && user.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/admin/review"><i class="bi bi-check-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Review' : '审核' %></a></li>
          <% } %>
          <li class="nav-item"><a class="nav-link active" href="/admin/cars"><i class="bi bi-car-front me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Cars' : '车辆管理' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars/create"><i class="bi bi-plus-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Add Car' : '添加车辆' %></a></li>
          <% if (user && user.role === 'admin') { %>
          <li class="nav-item"><a class="nav-link" href="/admin/users"><i class="bi bi-people me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Users' : '用户管理' %></a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'User' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="mb-0"><%= title %></h2>
      <a href="/admin/cars/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Add Car' : '添加车辆' %>
      </a>
    </div>

    <% if (cars && cars.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-dark">
          <tr>
            <th>ID</th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Brand' : '品牌' %></th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Model' : '型号' %></th>
            <th><%= t('car.registrationYear') %></th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Displacement' : '排量' %></th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Cost (CNY)' : '成本价(CNY)' %></th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Price (USD)' : '售价(USD)' %></th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Status' : '状态' %></th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Created' : '创建人' %></th>
            <th><%= t('nav.admin') === 'Admin Panel' ? 'Actions' : '操作' %></th>
          </tr>
        </thead>
        <tbody>
          <% cars.forEach(function(car) { %>
          <tr>
            <td><%= car.id %></td>
            <td><strong><%= car.brand %></strong></td>
            <td><%= car.model %></td>
            <td><%= car.year || '-' %></td>
            <td><%= car.displacement || '-' %></td>
            <td><%= car.cost_price ? '¥' + Number(car.cost_price).toLocaleString() : '-' %></td>
            <td class="text-danger fw-bold"><%= car.price ? '$' + Number(car.price).toLocaleString() : '-' %></td>
            <td>
              <% if (car.status === 'active') { %>
                <span class="badge bg-success"><%= t('car.forSale') %></span>
              <% } else if (car.status === 'pending') { %>
                <span class="badge bg-warning text-dark"><%= t('nav.admin') === 'Admin Panel' ? 'Pending' : '待审核' %></span>
              <% } else { %>
                <span class="badge bg-secondary"><%= t('car.sold') %></span>
              <% } %>
            </td>
            <td><small><%= car.creator_name || 'System' %></small></td>
            <td>
              <div class="btn-group btn-group-sm">
                <% if (car.status === 'pending' && user && user.role === 'admin') { %>
                <a href="/admin/review/<%= car.id %>" class="btn btn-warning" title="<%= t('nav.admin') === 'Admin Panel' ? 'Review' : '审核' %>">
                  <i class="bi bi-check-circle"></i>
                </a>
                <% } %>
                <a href="/admin/cars/edit/<%= car.id %>" class="btn btn-outline-primary" title="<%= t('nav.admin') === 'Admin Panel' ? 'Edit' : '编辑' %>">
                  <i class="bi bi-pencil"></i>
                </a>
                <button type="button" class="btn btn-outline-danger" onclick="deleteCar(<%= car.id %>)" title="<%= t('nav.admin') === 'Admin Panel' ? 'Delete' : '删除' %>">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-emoji-frown text-muted" style="font-size: 4rem;"></i>
      <h4 class="mt-3 text-muted"><%= t('car.noCars') %></h4>
      <a href="/admin/cars/create" class="btn btn-primary mt-3">
        <i class="bi bi-plus-lg me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Add First Car' : '添加第一辆车' %>
      </a>
    </div>
    <% } %>
  </div>

  <form id="deleteForm" method="POST" style="display:none;">
    <input type="hidden" name="_method" value="DELETE">
  </form>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  function deleteCar(id) {
    if (confirm('<%= t("nav.admin") === "Admin Panel" ? "Are you sure you want to delete this car?" : "确定要删除这辆车吗？" %>')) {
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/admin/cars/delete/' + id;
      document.body.appendChild(form);
      form.submit();
    }
  }
  </script>
</body>
</html>
