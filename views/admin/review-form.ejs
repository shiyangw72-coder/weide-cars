<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin?lang=<%= lang %>"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars?lang=<%= lang %>"><i class="bi bi-car-front me-1"></i><%= t('admin.cars') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars/create?lang=<%= lang %>"><i class="bi bi-plus-circle me-1"></i><%= t('admin.addCar') %></a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/review?lang=<%= lang %>"><i class="bi bi-check-circle me-1"></i><%= t('admin.review') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users?lang=<%= lang %>"><i class="bi bi-people me-1"></i><%= t('admin.users') %></a></li>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'User' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <h2 class="mb-4"><%= title %></h2>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/review/<%= car.id %>?lang=<%= lang %>" enctype="multipart/form-data">
      <div class="row g-4">
        <div class="col-md-8">
          <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
              <i class="bi bi-car-front me-2"></i><%= car.brand %> <%= car.model %>
              <span class="badge bg-dark ms-2"><%= t('admin.pendingBadge') %></span>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-6">
                  <table class="table table-sm table-borderless">
                    <tr><td class="text-muted"><%= t('admin.brand') %>:</td><td><%= car.brand %></td></tr>
                    <tr><td class="text-muted"><%= t('admin.model') %>:</td><td><%= car.model %></td></tr>
                    <tr><td class="text-muted"><%= t('car.registrationYear') %>:</td><td><%= car.year || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.odometer') %>:</td><td><%= car.mileage ? Number(car.mileage).toLocaleString() + ' km' : '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('admin.category') %>:</td><td><%= car.category || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.fuelType') %>:</td><td><%= car.fuel_type || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.transmission') %>:</td><td><%= car.transmission || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.color') %>:</td><td><%= car.color || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('admin.displacement') %>:</td><td><%= car.displacement || '-' %></td></tr>
                  </table>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label class="form-label fw-bold"><%= t('admin.submittedBy') %></label>
                    <p><%= car.creator_name %></p>
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-bold"><%= t('admin.costPrice') %></label>
                    <p class="fs-5 text-primary"><%= car.cost_price ? '¥ ' + Number(car.cost_price).toLocaleString() : '-' %></p>
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-bold text-danger"><%= t('admin.setSalePrice') %> *</label>
                    <input type="number" name="price" class="form-control form-control-lg" step="0.01" min="0" required>
                    <small class="text-muted"><%= t('admin.setSalePriceHint') %></small>
                  </div>
                </div>
              </div>

              <hr>

              <div class="mb-3">
                <label class="form-label fw-bold"><%= t('car.description') %></label>
                <p class="bg-light p-3 rounded"><%= car.description || t('admin.noDescription') %></p>
              </div>

              <% if (car.media && car.media.length > 0) { %>
              <div class="mb-3">
                <label class="form-label fw-bold"><%= t('admin.uploadedMedia') %></label>
                <div class="row g-2">
                  <% car.media.forEach(function(item) { %>
                  <div class="col-3">
                    <div class="border rounded p-1 text-center" style="height: 120px; overflow: hidden;">
                      <% if (item.file_type === 'image') { %>
                        <img src="/media/<%= item.id %>" style="max-width:100%; max-height:100px;">
                      <% } else { %>
                        <video src="/media/<%= item.id %>" style="max-width:100%; max-height:100px;" controls></video>
                      <% } %>
                    </div>
                  </div>
                  <% }); %>
                </div>
              </div>
              <% } %>

              <%
                let existingImages = 0;
                let existingVideos = 0;
                if (car.media) {
                  car.media.forEach(m => { if (m.file_type === 'image') existingImages++; if (m.file_type === 'video') existingVideos++; });
                }
              %>
              <div class="mb-3">
                <label class="form-label"><%= t('admin.addExtraImages') %> (max 9, <%= existingImages %> / 9)</label>
                <input type="file" name="new_images" class="form-control" multiple accept="image/*">
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('admin.addExtraVideo') %> (max 1, <%= existingVideos %> / 1)</label>
                <input type="file" name="new_video" class="form-control" accept="video/*" <%= existingVideos >= 1 ? 'disabled' : '' %>>
              </div>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow-sm border-warning">
            <div class="card-header bg-warning text-dark">
              <i class="bi bi-check-circle me-2"></i><%= t('admin.reviewDecision') %>
            </div>
            <div class="card-body">
              <p class="text-muted small"><%= t('admin.reviewDecisionHint') %></p>
              <div class="d-grid gap-2">
                <button type="submit" name="action" value="approve" class="btn btn-success btn-lg">
                  <i class="bi bi-check-lg me-1"></i><%= t('admin.approvePublish') %>
                </button>
                <button type="submit" name="action" value="reject" class="btn btn-danger btn-lg">
                  <i class="bi bi-x-lg me-1"></i><%= t('admin.rejectDelete') %>
                </button>
              </div>
            </div>
          </div>

          <div class="mt-3">
            <a href="/admin/review?lang=<%= lang %>" class="btn btn-outline-secondary w-100">
              <i class="bi bi-arrow-left me-1"></i><%= t('admin.backToReview') %>
            </a>
          </div>
        </div>
      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
