<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= t('siteName') %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/?lang=<%= lang %>">
        <i class="bi bi-car-front-fill me-2"></i><%= t('siteName') %>
      </a>
      <span class="badge bg-warning text-dark me-2"><%= t('nav.adminBadge') %></span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="adminNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/admin"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.admin') %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars"><i class="bi bi-car-front me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Cars' : '车辆管理' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/cars/create"><i class="bi bi-plus-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Add Car' : '添加车辆' %></a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/review"><i class="bi bi-check-circle me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Review' : '审核' %></a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users"><i class="bi bi-people me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Users' : '用户管理' %></a></li>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/?lang=<%= lang %>"><i class="bi bi-house me-1"></i><%= t('nav.home') %></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user ? (user.display_name || user.username) : 'User' %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item text-danger" href="/auth/logout?lang=<%= lang %>"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <h2 class="mb-4"><%= title %></h2>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/review/<%= car.id %>" enctype="multipart/form-data">
      <div class="row g-4">
        <div class="col-md-8">
          <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
              <i class="bi bi-car-front me-2"></i><%= car.brand %> <%= car.model %> 
              <span class="badge bg-dark ms-2"><%= t('nav.admin') === 'Admin Panel' ? 'Pending Review' : '待审核' %></span>
            </div>
            <div class="card-body">
              <div class="row">
                <div class="col-md-6">
                  <table class="table table-sm table-borderless">
                    <tr><td class="text-muted"><%= t('nav.admin') === 'Admin Panel' ? 'Brand' : '品牌' %>:</td><td><%= car.brand %></td></tr>
                    <tr><td class="text-muted"><%= t('nav.admin') === 'Admin Panel' ? 'Model' : '型号' %>:</td><td><%= car.model %></td></tr>
                    <tr><td class="text-muted"><%= t('car.registrationYear') %>:</td><td><%= car.year || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.odometer') %>:</td><td><%= car.mileage ? Number(car.mileage).toLocaleString() + ' km' : '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('nav.admin') === 'Admin Panel' ? 'Category' : '分类' %>:</td><td><%= car.category || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.fuelType') %>:</td><td><%= car.fuel_type || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.transmission') %>:</td><td><%= car.transmission || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('car.color') %>:</td><td><%= car.color || '-' %></td></tr>
                    <tr><td class="text-muted"><%= t('nav.admin') === 'Admin Panel' ? 'Engine Displacement' : '排量' %>:</td><td><%= car.displacement || '-' %></td></tr>
                  </table>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label class="form-label fw-bold"><%= t('nav.admin') === 'Admin Panel' ? 'Submitted By' : '提交人' %></label>
                    <p><%= car.creator_name %></p>
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-bold"><%= t('nav.admin') === 'Admin Panel' ? 'Cost Price (CNY)' : '成本价（人民币）' %></label>
                    <p class="fs-5 text-primary"><%= car.cost_price ? '¥ ' + Number(car.cost_price).toLocaleString() : '-' %></p>
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-bold text-danger"><%= t('nav.admin') === 'Admin Panel' ? 'Set Sale Price (USD) *' : '设定售价（美金） *' %></label>
                    <input type="number" name="price" class="form-control form-control-lg" step="0.01" min="0" required>
                    <small class="text-muted"><%= t('nav.admin') === 'Admin Panel' ? 'This USD price will be displayed on the website.' : '该美金价格将显示在网站上。' %></small>
                  </div>
                </div>
              </div>

              <hr>

              <div class="mb-3">
                <label class="form-label fw-bold"><%= t('car.description') %></label>
                <p class="bg-light p-3 rounded"><%= car.description || (t('nav.admin') === 'Admin Panel' ? 'No description' : '暂无描述') %></p>
              </div>

              <% if (car.media && car.media.length > 0) { %>
              <div class="mb-3">
                <label class="form-label fw-bold"><%= t('nav.admin') === 'Admin Panel' ? 'Uploaded Media' : '上传的媒体' %></label>
                <div class="row g-2">
                  <% car.media.forEach(function(item) { %>
                  <div class="col-3">
                    <div class="border rounded p-1 text-center" style="height: 120px; overflow: hidden;">
                      <% if (item.file_type === 'image') { %>
                        <img src="<%= item.file_path %>" style="max-width:100%; max-height:100px;">
                      <% } else { %>
                        <video src="<%= item.file_path %>" style="max-width:100%; max-height:100px;" controls></video>
                      <% } %>
                    </div>
                  </div>
                  <% }); %>
                </div>
              </div>
              <% } %>

              <% 
                let existingImages = 0;
                let existingVideos = 0;
                if (car.media) {
                  car.media.forEach(m => { if (m.file_type === 'image') existingImages++; if (m.file_type === 'video') existingVideos++; });
                }
              %>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Add Extra Images (max 9 total, currently ' + existingImages + ')' : '补充图片（最多9张，当前' + existingImages + '张）' %></label>
                <input type="file" name="new_images" class="form-control" multiple accept="image/*">
              </div>
              <div class="mb-3">
                <label class="form-label"><%= t('nav.admin') === 'Admin Panel' ? 'Add Extra Video (max 1 total, currently ' + existingVideos + ')' : '补充视频（最多1个，当前' + existingVideos + '个）' %></label>
                <input type="file" name="new_video" class="form-control" accept="video/*" <%= existingVideos >= 1 ? 'disabled' : '' %>>
              </div>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow-sm border-warning">
            <div class="card-header bg-warning text-dark">
              <i class="bi bi-check-circle me-2"></i><%= t('nav.admin') === 'Admin Panel' ? 'Review Decision' : '审核决定' %>
            </div>
            <div class="card-body">
              <p class="text-muted small"><%= t('nav.admin') === 'Admin Panel' ? 'Approve will set the car to active and display it on the website. Reject will delete it.' : '通过将把车辆设为在售并显示在网站上；拒绝将删除该车辆。' %></p>
              <div class="d-grid gap-2">
                <button type="submit" name="action" value="approve" class="btn btn-success btn-lg">
                  <i class="bi bi-check-lg me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Approve & Publish' : '通过并发布' %>
                </button>
                <button type="submit" name="action" value="reject" class="btn btn-danger btn-lg">
                  <i class="bi bi-x-lg me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Reject & Delete' : '拒绝并删除' %>
                </button>
              </div>
            </div>
          </div>

          <div class="mt-3">
            <a href="/admin/review" class="btn btn-outline-secondary w-100">
              <i class="bi bi-arrow-left me-1"></i><%= t('nav.admin') === 'Admin Panel' ? 'Back to Review List' : '返回审核列表' %>
            </a>
          </div>
        </div>
      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
